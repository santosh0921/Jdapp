          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{base_url}}/admin/dashboard" }
        },
        {
          "name": "Get All Shipments",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/shipments?page=1&limit=50&status=in_transit", "query": [{"key":"page","value":"1"},{"key":"limit","value":"50"},{"key":"status","value":"in_transit"}] } }
        },
        {
          "name": "Get Courier Orders",
          "request": { "method": "GET", "url": "{{base_url}}/admin/courier-orders" }
        },
        {
          "name": "Get Logistics Orders",
          "request": { "method": "GET", "url": "{{base_url}}/admin/logistics-orders" }
        },
        {
          "name": "Get Users",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/users?page=1&limit=50", "query": [{"key":"page","value":"1"},{"key":"limit","value":"50"}] } }
        },
        {
          "name": "Get User by ID",
          "request": { "method": "GET", "url": "{{base_url}}/admin/users/{{user_id}}" }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/users/{{user_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"status\": \"active\", \"role\": \"courier_customer\" }" }
          }
        },
        {
          "name": "Get Drivers",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/drivers?page=1&limit=50", "query": [{"key":"page","value":"1"},{"key":"limit","value":"50"}] } }
        },
        {
          "name": "Get Driver by ID",
          "request": { "method": "GET", "url": "{{base_url}}/admin/drivers/{{driver_id}}" }
        },
        {
          "name": "Get Warehouses",
          "request": { "method": "GET", "url": "{{base_url}}/admin/warehouses" }
        },
        {
          "name": "Get Warehouse Details",
          "request": { "method": "GET", "url": "{{base_url}}/admin/warehouses/{{warehouse_id}}" }
        },
        {
          "name": "Get Warehouse Inventory",
          "request": { "method": "GET", "url": "{{base_url}}/admin/warehouses/{{warehouse_id}}/inventory" }
        },
        {
          "name": "Get Fleet",
          "request": { "method": "GET", "url": "{{base_url}}/admin/fleet" }
        },
        {
          "name": "Get Analytics",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/analytics?period=monthly", "query": [{"key":"period","value":"monthly"}] } }
        },
        {
          "name": "Get Payments",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/payments?page=1&limit=50", "query": [{"key":"page","value":"1"},{"key":"limit","value":"50"}] } }
        },
        {
          "name": "Get Reports",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/reports?type=revenue&period=monthly", "query": [{"key":"type","value":"revenue"},{"key":"period","value":"monthly"}] } }
        },
        {
          "name": "Get Audit Logs",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/audit-logs?page=1&limit=100", "query": [{"key":"page","value":"1"},{"key":"limit","value":"100"}] } }
        },
        {
          "name": "Get Security Events",
          "request": { "method": "GET", "url": "{{base_url}}/admin/security" }
        }
      ]
    }
  ]
}
