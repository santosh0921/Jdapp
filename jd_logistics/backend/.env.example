# Copy this file to .env and fill in your values
APP_ENV=development
PORT=8080

# ── PostgreSQL (Render: crednova_db) ────────────────────────────────────────
# Option A — full connection string (paste from Render dashboard)
# DATABASE_URL=postgresql://user:password@host.render.com/crednova_db?sslmode=require

# Option B — individual vars (used when DATABASE_URL is not set)
DB_HOST=dpg-xxxxxxxxxxxx-a.oregon-postgres.render.com
DB_PORT=5432
DB_USER=crednova_db_user
DB_PASSWORD=YOUR_RENDER_DB_PASSWORD
DB_NAME=crednova_db
DB_SSLMODE=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASS=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
